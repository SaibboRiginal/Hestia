# Chronos configuration
# Chronos is domain-only: it delegates provider auth/CRUD to Hecate.
# Copy this file to .env and override only what you need.

# ── Required service routing ───────────────────────────────────────────
HUB_API_URL=http://hestia_hub:19001/api
CALENDAR_SERVICE_BASE_URL=http://hestia_chronos:19007

# ── Runtime config ─────────────────────────────────────────────────────
CALENDAR_PORT=19007
CALENDAR_SERVICE_VERSION=1.0.0
STARTUP_WAIT_TIMEOUT_SECONDS=0

# ── Downstream services ────────────────────────────────────────────────
ARCHIVE_URL=http://hestia_archive:19002
HERMES_URL=http://hestia_hermes:19005

# ── Notifications ──────────────────────────────────────────────────────
NOTIFY_TARGET=
CHRONOS_NOTIFY_POLL_SECONDS=300
NOTIFY_LOOK_AHEAD_HOURS=26

# ── Calendar sync worker ───────────────────────────────────────────────
CHRONOS_SYNC_ENABLED=true
CHRONOS_SYNC_POLL_SECONDS=900
CHRONOS_SYNC_LOOK_BACK_DAYS=1
CHRONOS_SYNC_LOOK_AHEAD_DAYS=30
CHRONOS_SYNC_NOTIFY_NEW=true
CHRONOS_SYNC_CALENDAR_ID=primary

# ── Logging ────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
