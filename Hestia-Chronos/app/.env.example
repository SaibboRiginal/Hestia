# Calendar Service Configuration
# Copy this file to .env and fill in your credentials.

# ── Google Calendar ───────────────────────────────────────────────────
# Option 1: Service account (G-Suite / Workspace with domain delegation)
# Paste the full contents of your service account JSON file as a single line.
GOOGLE_SERVICE_ACCOUNT_JSON=

# Option 2: Personal Google account OAuth token
# Run scripts/google_oauth_setup.py once on the host to generate token.json,
# then paste its contents here.
GOOGLE_TOKEN_JSON=

# ── Microsoft Outlook ─────────────────────────────────────────────────
# Required for both personal and organizational Outlook accounts.
OUTLOOK_CLIENT_ID=
OUTLOOK_TENANT_ID=consumers

# For personal accounts: run scripts/outlook_oauth_setup.py to get a refresh token.
OUTLOOK_REFRESH_TOKEN=

# For organizational accounts: application client secret (client credentials flow).
OUTLOOK_CLIENT_SECRET=

# The user whose calendar to manage.
# Use "me" for delegated/personal flow, or "user@domain.com" for app flow.
OUTLOOK_USER_ID=me

# ── Service config ────────────────────────────────────────────────────
CALENDAR_PORT=8008
CALENDAR_SERVICE_VERSION=1.0.0
