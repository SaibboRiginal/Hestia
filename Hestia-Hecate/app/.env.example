# Hecate configuration
# Copy to .env and fill secrets.

# ── Core service routing ───────────────────────────────────────────────
HUB_API_URL=http://hestia_hub:19001/api
HECATE_SERVICE_BASE_URL=http://hestia_hecate:19003
HECATE_SERVICE_VERSION=1.0.0

# ── Archive integration (routed through Hub) ──────────────────────────
HECATE_ARCHIVE_ROUTE_TIMEOUT=8
HECATE_CALENDAR_WRITE_TIMEOUT=10
HECATE_CALENDAR_BACKFILL_DAYS=7

# ── Provider toggles (optional) ────────────────────────────────────────
HECATE_ENABLE_PROVIDER_GOOGLE=false
HECATE_ENABLE_PROVIDER_MICROSOFT=false

# ── Google provider (OAuth or service account) ────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_TOKEN_JSON=
GOOGLE_CREDENTIALS_JSON=
GOOGLE_SERVICE_ACCOUNT_JSON=

# ── Microsoft provider ────────────────────────────────────────────────
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_TENANT_ID=consumers
OUTLOOK_REFRESH_TOKEN=
OUTLOOK_USER_ID=me

# ── Email fetch connector target (generic, no module hardcoding) ──────
HECATE_EMAIL_SERVICE=iris
HECATE_EMAIL_MESSAGES_PATH=/api/email/messages
HECATE_EMAIL_SOURCE_KEY=email

# ── Logging ────────────────────────────────────────────────────────────
LOG_LEVEL=INFO